<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tasks - EarnHub</title>
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="app-container">
    <header class="app-header">
      <div class="header-left">
        <a href="/" class="back-btn">&#8592;</a>
        <span class="page-title">Tasks</span>
      </div>
      <div class="header-right">
        <span class="balance-display">$<%= user.balance.toFixed(4) %></span>
      </div>
    </header>

    <main class="app-main">
      <div class="tasks-header">
        <p class="tasks-info">Complete tasks to earn extra income!</p>
      </div>

      <div class="tasks-list">
        <% tasks.forEach(task => { %>
          <div class="task-card" id="task-<%= task.id %>">
            <div class="task-left">
              <div class="task-icon <%= task.completed ? 'task-done' : 'task-ready' %>">
                <%= task.completed ? '&#10003;' : '&#9733;' %>
              </div>
              <div class="task-info">
                <h4><%= task.title %></h4>
                <p><%= task.description %></p>
                <span class="task-reward">+$<%= task.reward.toFixed(4) %></span>
                <span class="task-type badge badge-<%= task.type %>"><%= task.type %></span>
              </div>
            </div>
            <% if (!task.completed) { %>
              <button class="btn btn-primary btn-sm" onclick="completeTask(<%= task.id %>, this)">Complete</button>
            <% } else { %>
              <span class="badge badge-success">Done</span>
            <% } %>
          </div>
        <% }) %>

        <% if (tasks.length === 0) { %>
          <div class="empty-state">
            <p>No tasks available right now. Check back later!</p>
          </div>
        <% } %>
      </div>
    </main>

    <nav class="bottom-nav">
      <a href="/" class="nav-item">
        <img src="/img/favicon.svg" alt="Home" class="nav-svg">
        <span>Home</span>
      </a>
      <a href="/ads" class="nav-item">
        <img src="/img/icon-ads.svg" alt="Ads" class="nav-svg">
        <span>Ads</span>
      </a>
      <a href="/tasks" class="nav-item active">
        <img src="/img/icon-tasks.svg" alt="Tasks" class="nav-svg">
        <span>Tasks</span>
      </a>
      <a href="/profile" class="nav-item">
        <img src="/img/icon-profile.svg" alt="Profile" class="nav-svg">
        <span>Profile</span>
      </a>
    </nav>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>
